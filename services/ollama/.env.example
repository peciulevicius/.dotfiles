# Ollama + Open WebUI

OLLAMA_PORT=11434
WEBUI_PORT=3030

# Model storage — point to external SSD for large models
# Default: ./data/models (local)
# Recommended on Mac mini: /Volumes/T7/ollama-models
OLLAMA_MODELS_PATH=./data/models

# Open WebUI session key — generate: openssl rand -hex 32
WEBUI_SECRET_KEY=change_me
