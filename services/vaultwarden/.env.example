# Vaultwarden Configuration
# Generate ADMIN_TOKEN: openssl rand -base64 48

VW_PORT=8001
ADMIN_TOKEN=change_me_generate_with_openssl
# Use Cloudflare Tunnel URL for HTTPS (required for Bitwarden apps)
# Run: scripts/setup/setup-cloudflare-tunnel.sh
DOMAIN=https://vault.yourdomain.com
SIGNUPS_ALLOWED=false
