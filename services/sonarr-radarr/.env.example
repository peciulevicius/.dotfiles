# Sonarr + Radarr + Prowlarr Configuration

SONARR_PORT=8989
RADARR_PORT=7878
PROWLARR_PORT=9696
TZ=Europe/Vilnius
PUID=1000
PGID=1000

# Shared media directory on T7 SSD
# Structure:
#   /Volumes/T7/media/
#     downloads/    ← Transmission downloads here
#     movies/       ← Radarr moves completed movies here
#     tv/           ← Sonarr moves completed TV here
MEDIA_DIR=/Volumes/T7/media
