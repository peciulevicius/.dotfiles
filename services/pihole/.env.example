# Pi-hole Configuration

PIHOLE_WEB_PORT=8053
PIHOLE_DNS_PORT=53
PIHOLE_PASSWORD=changeme
TZ=Europe/Vilnius

# Mac mini local IP (for local DNS resolution)
LOCAL_IP=192.168.1.100

# Upstream DNS servers (semicolon-separated)
UPSTREAM_DNS=1.1.1.1;1.0.0.1

# --- Local DNS entries ---
# After starting Pi-hole, add local DNS records via the web UI:
# Settings → Local DNS → DNS Records
#
# Add these entries (replace IP with your Mac mini's local IP):
#   home.peciulevicius.com       → 192.168.1.100
#   vault.peciulevicius.com      → 192.168.1.100
#   photos.peciulevicius.com     → 192.168.1.100
#   cloud.peciulevicius.com      → 192.168.1.100
#   ai.peciulevicius.com         → 192.168.1.100
#   papers.peciulevicius.com     → 192.168.1.100
#   rss.peciulevicius.com        → 192.168.1.100
#   status.peciulevicius.com     → 192.168.1.100
#   books.peciulevicius.com      → 192.168.1.100
#   pdf.peciulevicius.com        → 192.168.1.100
#   tools.peciulevicius.com      → 192.168.1.100
#   links.peciulevicius.com      → 192.168.1.100
#   recipes.peciulevicius.com    → 192.168.1.100
#   watch.peciulevicius.com      → 192.168.1.100
#   sonarr.peciulevicius.com     → 192.168.1.100
#   radarr.peciulevicius.com     → 192.168.1.100
#   prowlarr.peciulevicius.com   → 192.168.1.100
#   downloads.peciulevicius.com  → 192.168.1.100
#
# Then set your router's DNS to:
#   Primary:   192.168.1.100 (Mac mini)
#   Secondary: 1.1.1.1 (fallback)
