# Rclone Backup Configuration
# Set up rclone remote first: rclone config
# R2 guide: https://rclone.org/s3/#cloudflare-r2

# Name of rclone remote (from `rclone listremotes`)
RCLONE_REMOTE=r2

# Source directory
DOCKER_DIR=/Users/yourusername/services

# Destination: remote:bucket/path
BACKUP_DEST=r2:peciulevicius-backups/services
OBSIDIAN_DEST=r2:peciulevicius-backups/obsidian-vault

# Rclone flags
RCLONE_FLAGS="--transfers=4 --checkers=8 --fast-list --stats=60s"
