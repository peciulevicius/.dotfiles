# Watchtower Configuration
# Runs at 4 AM by default (cron format: seconds minutes hours day month weekday)

WATCHTOWER_SCHEDULE=0 0 4 * * *
WATCHTOWER_CLEANUP=true
# Set to true to only update containers with com.centurylinklabs.watchtower.enable=true label
WATCHTOWER_LABEL_ENABLE=false
TZ=Europe/Vilnius
