# Immich Configuration
# Copy this to .env and fill in the values before running docker compose up -d

# Version pin (leave as 'release' to track latest stable)
IMMICH_VERSION=release

# Port on host machine
IMMICH_PORT=2283

# Photo library location — use absolute path for a mounted drive
# e.g. /Volumes/Photos/immich or ./library (relative to compose file)
UPLOAD_LOCATION=./library

# Database credentials — change the password before first run
DB_USERNAME=immich
DB_PASSWORD=change_me_strong_password
DB_DATABASE_NAME=immich
